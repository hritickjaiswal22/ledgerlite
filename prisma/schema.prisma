// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Currency {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(256)
  code      String   @unique @db.VarChar(3)
  symbol    String   @unique @db.VarChar(5)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Back Relation
  users User[]

  @@map("currencies")
}

model User {
  id                 String   @id @default(uuid()) @db.Uuid
  email              String   @unique @db.VarChar(256)
  password           String   @db.Text
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  selectedCurrencyId String   @map("selected_currency_id") @db.Uuid
  selectedCurrency   Currency @relation(fields: [selectedCurrencyId], references: [id])

  // Back Relations
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]

  @@map("users")
}

model Account {
  id        String   @id @default(uuid()) @db.Uuid

  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])

  name      String   @db.VarChar(256)
  balance   Decimal  @default(0.00) @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, name])

  // Back Relation
  transactions Transaction[]

  @@map("accounts")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid

  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])

  name      String   @db.VarChar(256)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, name])

  // Back Relations
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

enum TransactionType {
  income
  expense

  @@map("TRANSACTION_TYPE")
}

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid

  accountId       String          @map("account_id") @db.Uuid
  account         Account         @relation(fields: [accountId], references: [id])

  userId          String          @map("user_id") @db.Uuid
  user            User            @relation(fields: [userId], references: [id])

  categoryId      String          @map("category_id") @db.Uuid
  category        Category        @relation(fields: [categoryId], references: [id])

  amount          Decimal         @db.Decimal(15, 2)

  transactionType TransactionType @map("transaction_type")

  transactionDate DateTime        @map("transaction_date") @db.Timestamptz(6)

  description     String?         @db.VarChar(512)

  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("transactions")
}

model Budget {
  id         String   @id @default(uuid()) @db.Uuid

  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id])

  amount     Decimal  @db.Decimal(15, 2)

  month      Int      @db.SmallInt
  year       Int      @db.SmallInt

  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, categoryId, month, year])

  @@map("budgets")
}