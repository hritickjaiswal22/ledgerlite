generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Currency {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(256)
  code      String   @unique @db.VarChar(3)
  symbol    String   @unique @db.VarChar(5)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  users     User[]

  @@map("currencies")
}

model User {
  id                 String        @id @default(uuid()) @db.Uuid
  email              String        @unique @db.VarChar(256)
  password           String
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  selectedCurrencyId String        @map("selected_currency_id") @db.Uuid
  accounts           Account[]
  budgets            Budget[]
  categories         Category[]
  transactions       Transaction[]
  selectedCurrency   Currency      @relation(fields: [selectedCurrencyId], references: [id])

  @@map("users")
}

model Account {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  name         String        @db.VarChar(256)
  balance      Decimal       @default(0.00) @db.Decimal(15, 2)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  type         AccountType
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@unique([userId, name])
  @@map("accounts")
}

model Category {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  name         String        @db.VarChar(256)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  budgets      Budget[]
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@unique([userId, name])
  @@map("categories")
}

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid
  accountId       String          @map("account_id") @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  categoryId      String          @map("category_id") @db.Uuid
  amount          Decimal         @db.Decimal(15, 2)
  transactionType TransactionType @map("transaction_type")
  transactionDate DateTime        @map("transaction_date") @db.Timestamptz(6)
  description     String?         @db.VarChar(512)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  account         Account         @relation(fields: [accountId], references: [id])
  category        Category        @relation(fields: [categoryId], references: [id])
  user            User            @relation(fields: [userId], references: [id])

  @@index([userId, transactionDate, categoryId, amount], map: "idx_transactions_expense", where: raw("(transaction_type = 'expense'::\"TRANSACTION_TYPE\")"))
  @@index([userId, transactionDate, categoryId, amount], map: "idx_transactions_income", where: raw("(transaction_type = 'income'::\"TRANSACTION_TYPE\")"))
  @@map("transactions")
}

model Budget {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  amount     Decimal  @db.Decimal(15, 2)
  month      Int      @db.SmallInt
  year       Int      @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  category   Category @relation(fields: [categoryId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD

  @@map("ACCOUNT_TYPE")
}

enum TransactionType {
  income
  expense

  @@map("TRANSACTION_TYPE")
}
